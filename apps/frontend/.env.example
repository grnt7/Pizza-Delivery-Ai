# Copy to `.env` in this folder (next to app.json).
# Expo embeds only variables prefixed with EXPO_PUBLIC_ — restart: npx expo start -c
#
# Never put CLERK_SECRET_KEY here; that belongs in Convex dashboard + backend/.env.local only.

EXPO_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Stripe (native Payment Sheet + Apple Pay plugin). Uses your Stripe publishable key (pk_test_… / pk_live_…).
# Never put the Stripe secret key here — Convex dashboard only.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
